# The soul is a PUBLIC gitlawb repo — never commit secrets or runtime droppings.

# Python build artifacts
__pycache__/
*.pyc

# Rotated token stores / API creds (defense-in-depth; should never live in the soul)
*.tokens.json
*.x.txt
*.env
*.pem

# OS / editor
.DS_Store

# Delegated-worker workspaces (Phase 14) — per-run scratch the harness creates + GCs. NEVER commit:
# this dir is REQUIRED to be gitignored, else the soul-integrity tripwire reverts (deletes) worker
# output every cycle (the harness hard-fails at boot if this line is missing while worker_sandbox is on).
workspaces/
